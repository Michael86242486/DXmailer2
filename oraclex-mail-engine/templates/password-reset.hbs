<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Your Password</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #0d0d0d; color: #e8e8e8; -webkit-font-smoothing: antialiased;
    }
    .wrapper { width: 100%; padding: 48px 16px; }
    .card {
      max-width: 560px; margin: 0 auto; background: #141414;
      border: 1px solid #2a2a2a; border-radius: 16px; overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #2e1a1a 0%, #211616 50%, #340f0f 100%);
      padding: 40px 40px 36px; text-align: center; border-bottom: 1px solid #5f1e1e;
    }
    .brand { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #ff7a4a; margin-bottom: 12px; }
    .header h1 { font-size: 22px; font-weight: 700; color: #ffffff; }
    .body { padding: 40px; }
    .greeting { font-size: 15px; color: #a0a0a0; line-height: 1.6; margin-bottom: 32px; }
    .btn-container { text-align: center; margin-bottom: 32px; }
    .btn {
      display: inline-block; background: #ff7a4a; color: #ffffff !important;
      text-decoration: none; font-weight: 700; font-size: 15px;
      padding: 14px 36px; border-radius: 8px; letter-spacing: 0.02em;
    }
    .link-fallback { font-size: 12px; color: #555; text-align: center; margin-bottom: 32px; line-height: 1.6; }
    .link-fallback a { color: #ff7a4a; word-break: break-all; }
    .expiry { font-size: 13px; color: #666; text-align: center; margin-bottom: 32px; }
    .expiry strong { color: #a0a0a0; }
    .divider { border: none; border-top: 1px solid #2a2a2a; margin: 32px 0; }
    .security-note {
      background: #1a1a1a; border: 1px solid #2a2a2a; border-left: 3px solid #e85555;
      border-radius: 8px; padding: 16px 18px; font-size: 13px; color: #888; line-height: 1.5; margin-bottom: 32px;
    }
    .security-note strong { color: #e85555; }
    .footer { padding: 24px 40px; border-top: 1px solid #1e1e1e; text-align: center; }
    .footer-company { font-size: 13px; font-weight: 600; color: #ff7a4a; margin-bottom: 4px; }
    .footer-year { font-size: 11px; color: #444; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <div class="brand">{{company}}</div>
        <h1>Reset Your Password</h1>
      </div>
      <div class="body">
        <p class="greeting">
          We received a request to reset the password for your {{company}} account.
          Click the button below to choose a new password.
        </p>
        {{#if resetUrl}}
        <div class="btn-container">
          <a href="{{resetUrl}}" class="btn">Reset Password</a>
        </div>
        <p class="link-fallback">
          If the button doesn't work, copy and paste this link into your browser:<br />
          <a href="{{resetUrl}}">{{resetUrl}}</a>
        </p>
        {{/if}}
        {{#if code}}
        <div style="margin-bottom:32px;">
          <div style="font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#666;margin-bottom:12px;">Reset code</div>
          <div style="background:#1a1a1a;border:1px solid #2e2e2e;border-radius:12px;padding:20px 24px;text-align:center;">
            <span style="font-family:'SF Mono','Fira Code',Menlo,monospace;font-size:32px;font-weight:800;color:#ff7a4a;letter-spacing:10px;white-space:nowrap;">{{code}}</span>
          </div>
        </div>
        {{/if}}
        <p class="expiry">This link / code expires in <strong>30 minutes</strong></p>
        <hr class="divider" />
        <div class="security-note">
          <strong>Didn't request this?</strong> If you didn't ask to reset your password, you can safely
          ignore this email. Your password will not change.
        </div>
      </div>
      <div class="footer">
        <div class="footer-company">{{company}}</div>
        <div class="footer-year">&copy; {{date}} · All rights reserved</div>
      </div>
    </div>
  </div>
</body>
</html>
