<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your Magic Sign-In Link</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #0d0d0d; color: #e8e8e8; -webkit-font-smoothing: antialiased;
    }
    .wrapper { width: 100%; padding: 48px 16px; }
    .card {
      max-width: 560px; margin: 0 auto; background: #141414;
      border: 1px solid #2a2a2a; border-radius: 16px; overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #2e1a5f 100%);
      padding: 40px 40px 36px; text-align: center; border-bottom: 1px solid #3e1e9f;
    }
    .brand { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #a04aff; margin-bottom: 12px; }
    .header h1 { font-size: 22px; font-weight: 700; color: #ffffff; }
    .body { padding: 40px; }
    .greeting { font-size: 15px; color: #a0a0a0; line-height: 1.6; margin-bottom: 32px; }
    .btn-container { text-align: center; margin-bottom: 32px; }
    .btn {
      display: inline-block; background: linear-gradient(135deg, #7928ca, #a04aff);
      color: #ffffff !important; text-decoration: none; font-weight: 700; font-size: 15px;
      padding: 14px 36px; border-radius: 8px; letter-spacing: 0.02em;
    }
    .link-fallback { font-size: 12px; color: #555; text-align: center; margin-bottom: 32px; line-height: 1.6; }
    .link-fallback a { color: #a04aff; word-break: break-all; }
    .expiry { font-size: 13px; color: #666; text-align: center; margin-bottom: 32px; }
    .expiry strong { color: #a0a0a0; }
    .divider { border: none; border-top: 1px solid #2a2a2a; margin: 32px 0; }
    .security-note {
      background: #1a1a1a; border: 1px solid #2a2a2a; border-left: 3px solid #e85555;
      border-radius: 8px; padding: 16px 18px; font-size: 13px; color: #888; line-height: 1.5; margin-bottom: 32px;
    }
    .security-note strong { color: #e85555; }
    .footer { padding: 24px 40px; border-top: 1px solid #1e1e1e; text-align: center; }
    .footer-company { font-size: 13px; font-weight: 600; color: #a04aff; margin-bottom: 4px; }
    .footer-year { font-size: 11px; color: #444; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <div class="brand">{{company}}</div>
        <h1>Your Magic Sign-In Link</h1>
      </div>
      <div class="body">
        <p class="greeting">
          Click the button below to sign in instantly — no password required.
          This link can only be used once.
        </p>
        {{#if magicUrl}}
        <div class="btn-container">
          <a href="{{magicUrl}}" class="btn">Sign In to {{company}}</a>
        </div>
        <p class="link-fallback">
          If the button doesn't work, copy and paste this URL into your browser:<br />
          <a href="{{magicUrl}}">{{magicUrl}}</a>
        </p>
        {{/if}}
        <p class="expiry">This link expires in <strong>15 minutes</strong> and is single-use</p>
        <hr class="divider" />
        <div class="security-note">
          <strong>Didn't request this?</strong> If you didn't try to sign in, you can safely ignore
          this email. Your account is secure.
        </div>
      </div>
      <div class="footer">
        <div class="footer-company">{{company}}</div>
        <div class="footer-year">&copy; {{date}} · All rights reserved</div>
      </div>
    </div>
  </div>
</body>
</html>
