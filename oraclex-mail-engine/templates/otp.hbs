<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>One-Time Password</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #0d0d0d;
      color: #e8e8e8;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper { width: 100%; padding: 48px 16px; }
    .card {
      max-width: 560px;
      margin: 0 auto;
      background: #141414;
      border: 1px solid #2a2a2a;
      border-radius: 16px;
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #1a2e1a 0%, #162116 50%, #0f3418 100%);
      padding: 40px 40px 36px;
      text-align: center;
      border-bottom: 1px solid #1e5f1e;
    }
    .brand { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #4aff7a; margin-bottom: 12px; }
    .header h1 { font-size: 22px; font-weight: 700; color: #ffffff; }
    .body { padding: 40px; }
    .greeting { font-size: 15px; color: #a0a0a0; line-height: 1.6; margin-bottom: 32px; }
    .code-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #666; margin-bottom: 12px; }
    .code-container {
      display: flex; flex-direction: row; flex-wrap: nowrap;
      align-items: center; justify-content: center;
      background: #1a1a1a; border: 1px solid #2e2e2e; border-radius: 12px;
      padding: 20px 24px; margin-bottom: 12px;
    }
    .code-full {
      font-family: 'SF Mono', 'Fira Code', Menlo, monospace;
      font-size: 36px; font-weight: 800; color: #4aff7a;
      letter-spacing: 12px; white-space: nowrap; display: block; text-align: center;
    }
    .expiry { font-size: 13px; color: #666; text-align: center; margin-bottom: 32px; }
    .expiry strong { color: #a0a0a0; }
    .divider { border: none; border-top: 1px solid #2a2a2a; margin: 32px 0; }
    .security-note {
      background: #1a1a1a; border: 1px solid #2a2a2a; border-left: 3px solid #e85555;
      border-radius: 8px; padding: 16px 18px; font-size: 13px; color: #888; line-height: 1.5; margin-bottom: 32px;
    }
    .security-note strong { color: #e85555; }
    .footer { padding: 24px 40px; border-top: 1px solid #1e1e1e; text-align: center; }
    .footer-company { font-size: 13px; font-weight: 600; color: #4aff7a; margin-bottom: 4px; }
    .footer-year { font-size: 11px; color: #444; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <div class="brand">{{company}}</div>
        <h1>One-Time Password</h1>
      </div>
      <div class="body">
        <p class="greeting">
          Use the OTP below to complete your action. This code expires in <strong style="color:#e8e8e8;">5 minutes</strong>.
        </p>
        <div class="code-label">Your OTP</div>
        <div class="code-container">
          <span class="code-full">{{code}}</span>
        </div>
        <p class="expiry">Expires in <strong>5 minutes</strong> &nbsp;·&nbsp; Single use only</p>
        <hr class="divider" />
        <div class="security-note">
          <strong>Security notice:</strong> Never share this OTP with anyone. {{company}} staff will never ask for it.
        </div>
      </div>
      <div class="footer">
        <div class="footer-company">{{company}}</div>
        <div class="footer-year">&copy; {{date}} · All rights reserved</div>
      </div>
    </div>
  </div>
</body>
</html>
