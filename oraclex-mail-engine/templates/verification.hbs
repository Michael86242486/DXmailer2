<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>Verification Code</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #0d0d0d;
      color: #e8e8e8;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      width: 100%;
      padding: 48px 16px;
    }
    .card {
      max-width: 560px;
      margin: 0 auto;
      background: #141414;
      border: 1px solid #2a2a2a;
      border-radius: 16px;
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      padding: 40px 40px 36px;
      text-align: center;
      border-bottom: 1px solid #1e3a5f;
    }
    .brand {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #4a9eff;
      margin-bottom: 12px;
    }
    .header h1 {
      font-size: 22px;
      font-weight: 700;
      color: #ffffff;
      letter-spacing: -0.3px;
    }
    .body {
      padding: 40px;
    }
    .greeting {
      font-size: 15px;
      color: #a0a0a0;
      line-height: 1.6;
      margin-bottom: 32px;
    }
    .code-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #666;
      margin-bottom: 12px;
    }
    /* Mobile fix: wide flex container so 6-digit code never wraps */
    .code-container {
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #1a1a1a;
      border: 1px solid #2e2e2e;
      border-radius: 12px;
      padding: 20px 24px;
      margin-bottom: 32px;
      min-width: 0;
    }
    .code-digit {
      display: inline-block;
      font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', Menlo, monospace;
      font-size: 36px;
      font-weight: 800;
      color: #4a9eff;
      letter-spacing: 0;
      line-height: 1;
      white-space: nowrap;
      flex-shrink: 0;
    }
    /* Fallback for email clients that don't support flex */
    .code-full {
      font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', Menlo, monospace;
      font-size: 36px;
      font-weight: 800;
      color: #4a9eff;
      letter-spacing: 12px;
      line-height: 1;
      white-space: nowrap;
      display: block;
      text-align: center;
      padding: 20px 24px;
    }
    .expiry {
      font-size: 13px;
      color: #666;
      text-align: center;
      margin-bottom: 32px;
    }
    .expiry strong {
      color: #a0a0a0;
    }
    .divider {
      border: none;
      border-top: 1px solid #2a2a2a;
      margin: 32px 0;
    }
    .security-note {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-left: 3px solid #e85555;
      border-radius: 8px;
      padding: 16px 18px;
      font-size: 13px;
      color: #888;
      line-height: 1.5;
      margin-bottom: 32px;
    }
    .security-note strong {
      color: #e85555;
    }
    .footer {
      padding: 24px 40px;
      border-top: 1px solid #1e1e1e;
      text-align: center;
    }
    .footer-company {
      font-size: 13px;
      font-weight: 600;
      color: #4a9eff;
      margin-bottom: 4px;
    }
    .footer-year {
      font-size: 11px;
      color: #444;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <div class="brand">{{company}}</div>
        <h1>Email Verification</h1>
      </div>

      <div class="body">
        <p class="greeting">
          To complete your verification, enter the code below. This code is valid for
          <strong style="color:#e8e8e8;">10 minutes</strong>.
        </p>

        <div class="code-label">Your verification code</div>

        <!--[if mso]>
        <table role="presentation" border="0" cellpadding="0" cellspacing="0" align="center" width="100%">
          <tr><td align="center" style="font-family:Courier New,monospace;font-size:36px;font-weight:bold;color:#4a9eff;letter-spacing:12px;padding:20px;">{{code}}</td></tr>
        </table>
        <![endif]-->
        <!--[if !mso]><!-->
        <div class="code-container" role="text" aria-label="Verification code: {{code}}">
          {{#each digits}}
          <span class="code-digit">{{this}}</span>
          {{else}}
          <span class="code-full">{{code}}</span>
          {{/each}}
        </div>
        <!--<![endif]-->

        <p class="expiry">
          Expires in <strong>10 minutes</strong> &nbsp;·&nbsp; Do not share this code
        </p>

        <hr class="divider" />

        <div class="security-note">
          <strong>Security notice:</strong> {{company}} will never ask for this code over phone or
          chat. If you did not request this, you can safely ignore this email.
        </div>
      </div>

      <div class="footer">
        <div class="footer-company">{{company}}</div>
        <div class="footer-year">&copy; {{date}} · All rights reserved</div>
      </div>
    </div>
  </div>
</body>
</html>
